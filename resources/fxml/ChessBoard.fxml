<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml" fx:controller="application.controller.ChessBoardController">

    <top>
        <MenuBar>
            <Menu text="Options">
                <MenuItem fx:id="savePgnButton" text="Sauvegarder PGN" onAction="#savePGN"/>
                <MenuItem fx:id="loadPgnButton" text="Charger PGN" onAction="#loadPGN"/>
                <MenuItem fx:id="soundToggleButton" text="Activer/Couper son" onAction="#toggleSound"/>
            </Menu>
        </MenuBar>
    </top>

    <center>
        <GridPane fx:id="boardGrid" hgap="0" vgap="0">
            <padding>
                <Insets top="10" right="10" bottom="10" left="10"/>
            </padding>
        </GridPane>
    </center>

</BorderPane>