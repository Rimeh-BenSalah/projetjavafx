<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.HBox?>
<?import javafx.geometry.Insets?>

<HBox xmlns:fx="http://javafx.com/fxml" fx:controller="application.controller.PromotionController" spacing="10" alignment="CENTER">
    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <Button fx:id="queenBtn" text="♕" onAction="#selectQueen" style="-fx-font-size:24px;"/>
    <Button fx:id="rookBtn" text="♖" onAction="#selectRook" style="-fx-font-size:24px;"/>
    <Button fx:id="bishopBtn" text="♗" onAction="#selectBishop" style="-fx-font-size:24px;"/>
    <Button fx:id="knightBtn" text="♘" onAction="#selectKnight" style="-fx-font-size:24px;"/>
</HBox>